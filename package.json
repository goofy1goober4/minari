{
  "name": "minari",
  "version": "0.0.1",
  "private": true,
  "description": "The grown-up's plushie. Except this one notices you back.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:win": "electron-vite build && electron-builder --win",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test:regression": "node --experimental-strip-types --no-warnings scripts/regression.ts",
    "demo:alarm": "node scripts/demo-alarm.js",
    "postinstall": "node node_modules/@electron/rebuild/lib/cli.js -f -w better-sqlite3 && node scripts/patch-live2d-engine.mjs"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.ojuyong.minari",
    "productName": "Minari",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  },
  "dependencies": {
    "better-sqlite3": "^11.6.0",
    "pixi.js": "^8.6.0",
    "untitled-pixi-live2d-engine": "^1.1.0"
  }
}
